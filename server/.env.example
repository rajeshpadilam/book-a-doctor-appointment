# Rename this file to .env before running the server

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/docbook
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/docbook
MONGO_URI=mongodb://127.0.0.1:27017/docbook

# Secret used to sign JWT tokens - change this to a long random string
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the API server listens on
PORT=5000

# URL of the frontend (used for CORS)
CLIENT_URL=http://localhost:5173
